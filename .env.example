APP_PORT=3000

POSTGRES_USER=service
POSTGRES_PASSWORD=superstrongpassword
POSTGRES_DB=service
POSTGRES_MAX_CONNS=100

JWT_SECRET=change-me
JWT_COOKIE_SECURE=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=prodhugsbot

# Matrix bot — leave MATRIX_ACCESS_TOKEN empty to disable the integration.
# Obtain an access token by logging the bot account in via /_matrix/client/v3/login.
MATRIX_HOMESERVER_URL=https://matrix.org
MATRIX_USER_ID=@prodhugsbot:matrix.org
MATRIX_ACCESS_TOKEN=

# Grafana Cloud (metrics via Alloy)
# Find these values in Grafana Cloud -> Connections -> Hosted Prometheus Metrics
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-XX-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USERNAME=123456
GRAFANA_CLOUD_API_KEY=glc_xxx

# Grafana Cloud (logs via Alloy -> Loki)
# Find these values in Grafana Cloud -> Connections -> Hosted Logs
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=123456
